APP_ENV=test

# Database Configuration
DB_HOST=127.0.0.1:8997
DB_USERNAME=splk
DB_PASSWORD=splk
DB_NAME=splk

# JWT Secret
JWT_SECRET=my_little_secret

# CORS Configuration
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080,http://127.0.0.1:3000,http://127.0.0.1:8000

# File Upload Configuration
MAX_UPLOAD_SIZE_MB=10
UPLOAD_ALLOWED_EXTENSIONS=pdf,doc,docx,xls,xlsx,txt,png,jpg,jpeg,gif,csv

# Rate Limiting Configuration - VERY HIGH FOR TESTING
RATE_LIMIT_GUEST=10000
RATE_LIMIT_USER=10000
RATE_LIMIT_ADMIN=10000

# Logging
LOG_PATH=../../log/api/app.log
LOG_LEVEL=DEBUG
