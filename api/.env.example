# Application Environment
# Values: local, production
APP_ENV=local

# Database Configuration
DB_HOST=localhost:8997
DB_USERNAME=splk
DB_PASSWORD=splk
DB_NAME=splk

# JWT Secret (REQUIRED - generate a strong random value)
# IMPORTANT: Must be at least 32 characters for security
# Generate secure secret: openssl rand -base64 32
# DO NOT use the example below in production
JWT_SECRET=your-very-long-random-secret-at-least-32-characters

# JWT Token Expiration (in seconds, default 900 = 15 minutes)
JWT_EXPIRATION=900

# File Upload Configuration
# Maximum upload size in MB (default 10)
MAX_UPLOAD_SIZE_MB=10

# Allowed file extensions (comma-separated)
UPLOAD_ALLOWED_EXTENSIONS=pdf,doc,docx,xls,xlsx,txt,png,jpg,jpeg,gif,csv

# Rate Limiting Configuration
# Requests per minute by role
RATE_LIMIT_GUEST=10
RATE_LIMIT_USER=100
RATE_LIMIT_ADMIN=1000

# Bulk Operations Configuration
# Maximum records per bulk create/update/delete request (default 100)
BULK_MAX_RECORDS=100

# Logging
LOG_PATH=../../log/api/app.log
LOG_LEVEL=DEBUG

# CORS Configuration (comma-separated list of allowed origins)
# Local development example:
# CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080,http://127.0.0.1:3000
# Production example:
# CORS_ALLOWED_ORIGINS=https://app.example.com,https://admin.example.com
# Subdomain wildcard:
# CORS_ALLOWED_ORIGINS=https://*.example.com
# IMPORTANT: Never use wildcard (*) - always specify exact domains
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080
